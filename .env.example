# Copy to .env and set real values. Backend loads backend/.env (not the repo root).

# Python: use 64-bit CPython 3.11 (see .python-version).

# Optional: PaddleX cache (defaults to backend/storage/.paddlex if unset).
# PADDLE_PDX_CACHE_HOME=

# Tesseract: full path to tesseract.exe on Windows, or leave unset to auto-detect
# (Program Files, winget path, PATH).
TESSERACT_CMD=

# Indus reconstruction API (required for Indus path; OCR still runs without it).
INDUS_API_URL=
INDUS_API_KEY=
# Optional; defaults to INDUS_API_URL if unset. Prefer a lightweight GET /health URL.
INDUS_HEALTH_URL=
INDUS_MODEL=handwriting-normalization
INDUS_TIMEOUT_SECONDS=25

# If true, the API process exits on startup when neither Paddle nor Tesseract works.
OCR_STRICT_STARTUP=false

# Existing app vars (e.g. Ollama) may also live in this file.
