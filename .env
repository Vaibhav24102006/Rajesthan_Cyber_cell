# Backend runtime environment variables for OCR lab and Indus reconstruction

# Tesseract executable path (Windows). Required if Tesseract is not already on PATH.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Optional Indus AI reconstruction service configuration.
# Set INDUS_API_URL and INDUS_API_KEY to enable the reconstruction pipeline.
# If INDUS_API_URL is unset, the OCR lab will fallback to local correction.
INDUS_API_URL=
INDUS_API_KEY=
INDUS_HEALTH_URL=
INDUS_MODEL=handwriting-normalization
INDUS_TIMEOUT_SECONDS=25

# Exit process on startup if no OCR backend (Paddle or Tesseract) is usable.
OCR_STRICT_STARTUP=false

# OCR runtime policy
OCR_LIGHTWEIGHT_MODE=auto
OCR_LIGHTWEIGHT_FILE_SIZE_MB_THRESHOLD=3.0
OCR_LIGHTWEIGHT_OCR_RUNTIME_MS_THRESHOLD=15000
OCR_LIGHTWEIGHT_MEMORY_PERCENT_THRESHOLD=85
OCR_LIGHTWEIGHT_MIN_AVAILABLE_GB=1.2
